{
  "name": "@your-scope/chat-widget",
  "description": "Reusable AI Chat Widget for Next.js + Streaming APIs",
  "version": "1.0.0",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pack:build": "tsup",
    "pack:dev": "tsup --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run pack:build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "next": "^14 || ^15"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.5"
  },
  "keywords": [
    "chat",
    "widget",
    "ai",
    "react",
    "nextjs",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/chat-widget.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/chat-widget/issues"
  },
  "homepage": "https://github.com/your-org/chat-widget#readme"
}
